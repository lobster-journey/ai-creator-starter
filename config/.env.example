# AI Creator Starter - 环境配置示例
# 复制此文件为 .env 并填入你的配置

# ============ 基础配置 ============

# 环境
ENV=development  # development/staging/production

# 调试模式
DEBUG=true

# 时区
TIMEZONE=Asia/Shanghai

# ============ LLM配置 ============

# LLM提供商
LLM_PROVIDER=oneapi  # openai/anthropic/oneapi

# API密钥
LLM_API_KEY=sk-xxxx

# API地址
LLM_API_BASE=https://api.oneapi.com/v1

# 模型选择
LLM_MODEL=claude-3-5-sonnet-20241022

# ============ 平台配置 ============

## 小红书
XIAOHONGSHU_ENABLED=true
XIAOHONGSHU_COOKIES_PATH=config/cookies/xiaohongshu.json

## 抖音
DOUYIN_ENABLED=false
DOUYIN_COOKIES_PATH=config/cookies/douyin.json

## B站
BILIBILI_ENABLED=false
BILIBILI_COOKIES_PATH=config/cookies/bilibili.json

## 微博
WEIBO_ENABLED=false
WEIBO_COOKIES_PATH=config/cookies/weibo.json

# ============ 图像生成配置 ============

# 图像生成提供商
IMAGE_PROVIDER=dreamina  # dreamina/midjourney/dalle

# 即梦API
DREAMINA_API_KEY=xxxx
DREAMINA_API_URL=https://api.dreamina.com

# ============ 数据库配置 ============

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ai_creator

# Redis
REDIS_URL=redis://localhost:6379/0

# ============ 安全配置 ============

# 加密密钥（用于加密Cookie等敏感信息）
SECRET_KEY=your-secret-key-here

# 允许访问的用户（逗号分隔）
ALLOWED_USERS=user1,user2

# ============ 运营配置 ============

## 发布频率限制
MAX_PUBLISH_PER_HOUR=3
MAX_PUBLISH_PER_DAY=20

## 评论频率限制
MAX_COMMENT_PER_HOUR=10
MAX_COMMENT_PER_DAY=50

## 工作时间
WORK_START_HOUR=9
WORK_END_HOUR=22

# ============ 监控配置 ============

# Prometheus
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=false
GRAFANA_PORT=3000

# ============ 日志配置 ============

# 日志级别
LOG_LEVEL=INFO  # DEBUG/INFO/WARNING/ERROR/CRITICAL

# 日志文件
LOG_FILE=logs/app.log

# 日志大小（MB）
LOG_MAX_SIZE=10

# 日志备份数
LOG_BACKUP_COUNT=5

# ============ 通知配置 ============

# 如流通知
INFOFLOW_ENABLED=true
INFOFLOW_WEBHOOK=https://xxx

# 邮件通知
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@example.com
EMAIL_SMTP_PASSWORD=your-password
EMAIL_TO=recipient@example.com

# ============ 高级配置 ============

## 浏览器配置
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

## 重试配置
MAX_RETRY_TIMES=3
RETRY_DELAY=5

## 超时配置
API_TIMEOUT=30
UPLOAD_TIMEOUT=60
